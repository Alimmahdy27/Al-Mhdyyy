    <script>
        // Data alarm
        let alarms = JSON.parse(localStorage.getItem('alarms')) || [];

        // Fungsi untuk menampilkan section
        function showSection(sectionId) {
            // Sembunyikan semua section
            document.querySelectorAll('.section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Tampilkan section yang dipilih
            document.getElementById(sectionId).classList.add('active');
            
            // Scroll ke atas
            window.scrollTo(0, 0);
            
            // Update daftar alarm jika section alarm yang dibuka
            if (sectionId === 'alarm') {
                tampilkanDaftarAlarm();
            }
        }

        // Fungsi untuk menampilkan notifikasi
        function tampilkanNotifikasi(pesan, isPengingat = false) {
            const notification = document.getElementById('notification');
            const message = document.getElementById('notificationMessage');
            
            if (isPengingat) {
                message.innerHTML = `⏰ PENGINGAT: ${pesan}`;
                notification.style.background = '#f8d7da';
                notification.style.borderLeft = '5px solid #dc3545';
            } else {
                message.textContent = pesan;
                notification.style.background = 'white';
                notification.style.borderLeft = '5px solid #28a745';
            }
            
            notification.classList.add('show');
            
            // Auto close setelah 5 detik
            setTimeout(() => {
                notification.classList.remove('show');
            }, 5000);
        }

        function tutupNotifikasi() {
            document.getElementById('notification').classList.remove('show');
        }

        // Fungsi untuk meminta izin notifikasi
        function mintaIzinNotifikasi() {
            if ('Notification' in window) {
                Notification.requestPermission().then(permission => {
                    if (permission === 'granted') {
                        tampilkanNotifikasi('Notifikasi diaktifkan! Anda akan mendapat pengingat minum obat');
                    } else {
                        alert('Izin notifikasi ditolak. Aktifkan melalui pengaturan browser untuk mendapat pengingat');
                    }
                });
            } else {
                alert('Browser Anda tidak mendukung notifikasi');
            }
        }

        // Fungsi untuk menambah alarm
        function tambahAlarm() {
            const namaObat = document.getElementById('namaObat').value;
            const waktuMinum = document.getElementById('waktuMinum').value;
            const frekuensi = document.getElementById('frekuensi').value;
            const dosis = document.getElementById('dosis').value;

            if (!namaObat || !waktuMinum || !frekuensi || !dosis) {
                tampilkanNotifikasi('Mohon lengkapi semua data!');
                return;
            }

            const alarm = {
                id: Date.now(),
                namaObat: namaObat,
                waktuMinum: waktuMinum,
                frekuensi: frekuensi,
                dosis: dosis,
                aktif: true,
                dibuat: new Date().toLocaleString('id-ID')
            };

            alarms.push(alarm);
            localStorage.setItem('alarms', JSON.stringify(alarms));
            
            tampilkanNotifikasi('Pengingat berhasil ditambahkan!');
            tampilkanDaftarAlarm();
            
            // Reset form
            document.getElementById('namaObat').value = '';
            document.getElementById('waktuMinum').value = '';
            document.getElementById('frekuensi').value = 'setiap hari';
            document.getElementById('dosis').value = '';

            // Set timeout untuk pengingat
            setAlarmTimeout(alarm);
        }

        // Fungsi untuk menampilkan daftar alarm
        function tampilkanDaftarAlarm() {
            const daftarAlarm = document.getElementById('daftarAlarm');
            
            if (alarms.length === 0) {
                daftarAlarm.innerHTML = '<p style="text-align: center; padding: 20px;">Belum ada pengingat yang ditambahkan</p>';
                return;
            }

            daftarAlarm.innerHTML = alarms.map(alarm => `
                <div class="alarm-item" id="alarm-${alarm.id}">
                    <div class="alarm-info">
                        <strong>${alarm.namaObat}</strong>
                        <p>⏰ Waktu: ${alarm.waktuMinum} | ${alarm.frekuensi}</p>
                        <p>💊 Dosis: ${alarm.dosis}</p>
                        <p>📅 Dibuat: ${alarm.dibuat}</p>
                    </div>
                    <div class="alarm-actions">
                        <button onclick="nonaktifkanAlarm(${alarm.id})" title="Nonaktifkan">⏸️</button>
                        <button onclick="hapusAlarm(${alarm.id})" title="Hapus">🗑️</button>
                    </div>
                </div>
            `).join('');
        }

        // Fungsi untuk menonaktifkan alarm
        function nonaktifkanAlarm(id) {
            alarms = alarms.map(alarm => {
                if (alarm.id === id) {
                    alarm.aktif = !alarm.aktif;
                }
                return alarm;
            });
            
            localStorage.setItem('alarms', JSON.stringify(alarms));
            tampilkanDaftarAlarm();
            tampilkanNotifikasi('Status alarm diperbarui');
        }

        // Fungsi untuk menghapus alarm
        function hapusAlarm(id) {
            alarms = alarms.filter(alarm => alarm.id !== id);
            localStorage.setItem('alarms', JSON.stringify(alarms));
            tampilkanDaftarAlarm();
            tampilkanNotifikasi('Pengingat dihapus');
        }

        // Fungsi untuk mengatur timeout alarm
        function setAlarmTimeout(alarm) {
            if (!alarm.aktif) return;

            const now = new Date();
            const [jam, menit] = alarm.waktuMinum.split(':');
            const alarmTime = new Date();
            alarmTime.setHours(parseInt(jam), parseInt(menit), 0);

            // Jika waktu sudah lewat, set untuk besok
            if (alarmTime < now) {
                alarmTime.setDate(alarmTime.getDate() + 1);
            }

            const waktuTunggu = alarmTime - now;

            setTimeout(() => {
                if (alarm.aktif) {
                    // Tampilkan notifikasi di halaman
                    tampilkanNotifikasi(`Waktu minum obat ${alarm.namaObat} (${alarm.dosis})`, true);
                    
                    // Tampilkan notifikasi sistem jika diizinkan
                    if (Notification.permission === 'granted') {
                        new Notification('💊 Pengingat Minum Obat', {
                            body: `Waktunya minum ${alarm.namaObat} - ${alarm.dosis}`,
                            icon: 'https://via.placeholder.com/100/28a745/ffffff?text=💊',
                            tag: alarm.id
                        });
                    }
                    
                    // Set untuk hari berikutnya
                    setAlarmTimeout(alarm);
                }
            }, waktuTunggu);
        }

        // Inisialisasi semua alarm saat halaman dimuat
        window.onload = function() {
            tampilkanDaftarAlarm();
            alarms.forEach(alarm => setAlarmTimeout(alarm));
            
            // Minta izin notifikasi
            if ('Notification' in window && Notification.permission === 'default') {
                mintaIzinNotifikasi();
            }
        };

        // Fungsi untuk navigasi menggunakan keyboard
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                tutupNotifikasi();
            }
        });

        // Smooth scroll untuk anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>
